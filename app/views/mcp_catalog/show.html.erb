<% content_for :navbar do %>
  <li class="flex items-center">
    <%= link_to "Settings", settings_path, class:"n-ariane n-main-focus" %>
  </li>
  <li class="flex gap-1 items-center">
    <%= inline_svg_tag "svg/chevron-right.svg", class: "shrink-0 h-5 w-5" %>
    <%= link_to "MCP servers", mcp_servers_path, class:"n-ariane n-main-focus" %>
  </li>
  <li class="flex gap-1 items-center">
    <%= inline_svg_tag "svg/chevron-right.svg", class: "shrink-0 h-5 w-5" %>
    <%= link_to "Catalog", mcp_catalog_index_path, class:"n-ariane n-main-focus" %>
  </li>
  <li class="flex gap-1 items-center">
    <%= inline_svg_tag "svg/chevron-right.svg", class: "shrink-0 h-5 w-5" %>
    <%= link_to @template[:name], mcp_catalog_path(@template[:id]), class:"n-ariane n-main-focus" %>
  </li>
<% end %>

<div class="mx-auto max-w-2xl">
  <div class="mb-6">
    <%= link_to mcp_catalog_index_path, class: "inline-flex items-center gap-1 text-sm text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 n-main-focus rounded-lg" do %>
      <%= inline_svg_tag "svg/chevron-left.svg", title: "Back", alt: "Chevron left", class: "h-4 w-4" %>
      Back to catalog
    <% end %>
  </div>

  <div class="n-card n-main-border">
    <div class="border-b n-main-border px-6 py-4">
      <div class="flex items-start gap-4">
        <span class="text-5xl shrink-0"><%= @template[:icon] %></span>
        <div>
          <h2 class="n-main-title text-wrap"><%= @template[:name] %></h2>
          <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400 text-wrap"><%= @template[:description] %></p>
        </div>
      </div>
    </div>

    <%= form_with url: mcp_catalog_index_path, method: :post, class: "p-6" do |form| %>
      <%= hidden_field_tag :id, @template[:id] %>
      <div class="space-y-6">
        <% if @template[:requires_config]&.any? %>
          <div class="rounded-lg bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 p-4">
            <h3 class="text-sm font-medium text-blue-800 dark:text-blue-200">Configuration required</h3>
            <p class="mt-1 text-sm text-blue-700 dark:text-blue-300">This server requires configuration before activation.</p>
          </div>

          <% @template[:requires_config].each do |config_field| %>
            <div class="n-form-field">
              <%= label_tag "config[#{config_field[:name]}]", class: "n-label" do %>
                <%= config_field[:label] %>
                <% if config_field[:required] %>
                  <span class="text-red-500">*</span>
                <% end %>
              <% end %>

              <% if config_field[:description] %>
                <p class="mb-2 text-xs text-neutral-500 dark:text-neutral-400"><%= config_field[:description] %></p>
              <% end %>

              <% case config_field[:type] %>
              <% when "secret", "password" %>
                <%= password_field_tag "config[#{config_field[:name]}]", "",
                  required: config_field[:required],
                  placeholder: config_field[:placeholder],
                  autocomplete: "off",
                  class: "n-field" %>

              <% when "path" %>
                <%= text_field_tag "config[#{config_field[:name]}]", "",
                  required: config_field[:required],
                  placeholder: config_field[:placeholder] || "/path/to/directory",
                  class: "n-field" %>

              <% when "select" %>
                <%= select_tag "config[#{config_field[:name]}]",
                  options_for_select(config_field[:options] || []),
                  required: config_field[:required],
                  class: "n-select" %>

              <% when "textarea" %>
                <%= text_area_tag "config[#{config_field[:name]}]", "",
                  required: config_field[:required],
                  placeholder: config_field[:placeholder],
                  rows: 3,
                  class: "n-textarea" %>

              <% else %>
                <%= text_field_tag "config[#{config_field[:name]}]", "",
                  required: config_field[:required],
                  placeholder: config_field[:placeholder],
                  class: "n-field" %>
              <% end %>

              <% if config_field[:help_text] %>
                <p class="mt-1 text-xs text-neutral-500 dark:text-neutral-400"><%= config_field[:help_text] %></p>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 p-4">
            <h3 class="text-sm font-medium text-green-800 dark:text-green-200">Ready to activate</h3>
            <p class="mt-1 text-sm text-green-700 dark:text-green-300">This server does not require any additional configuration.</p>
          </div>
        <% end %>

        <% if @template[:capabilities]&.any? %>
          <div>
            <h3 class="text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-3">Available capabilities</h3>
            <div class="flex flex-wrap gap-2">
              <% @template[:capabilities].each do |capability| %>
                <span class="n-tag n-tag-disconnected"><%= capability %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-8 flex gap-3">
        <%= link_to "Cancel", mcp_catalog_index_path, class: "flex-1 text-center n-btn border n-main-border n-main-hover-tertiary n-main-focus-tertiary" %>
        <%= form.submit "Activate #{@template[:name]}", class: "flex-1 n-btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
