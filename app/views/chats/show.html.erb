<div class="h-[calc(100vh-10.5rem)] lg:h-full flex flex-col justify-between"
     data-controller="chat-reconnect"
     data-chat-reconnect-generating-value="<%= @chat.generating? %>">
  <section data-controller="scroll" class="w-full overflow-y-auto">
    <div data-action="new-message-event-dispatcher:new_message@window->scroll#scrollToBottom" id="<%= dom_id(@chat) %>_messages" class="flex flex-col max-w-4xl mx-auto">
      <%= tag.div id: dom_id(@chat, :messages), data: { controller: "message-ordering" } do %>
        <%= render "chats/token_totals", chat: @chat %>
        <% @chat.messages.for_user.where.not(id: nil).order(:created_at).each do |message| %>
          <%= render message, message: %>
        <% end %>

        <%# Reconstruct in-progress generation from the reliable `generating` DB flag
            so a mid-stream page refresh isn't lost. ruby_llm persists the assistant
            message blank (content: "") until the stream ends, so it's excluded from
            `for_user` and never re-rendered — leaving streamed deltas (target
            dom_id(message, :content)) and the final broadcast_updated (target
            dom_id(message, :messages)) aiming at DOM nodes that don't exist. %>
        <% if @chat.generating? %>
          <% in_progress = @chat.messages.assistant.where(content: [ nil, "" ]).where.missing(:tool_calls).order(:created_at).last %>
          <% if in_progress %>
            <%# Streaming already started: render the bubble (shows the Generating
                placeholder) so live broadcasts have targets. broadcast_created
                already fired for this message, so no standalone animation here. %>
            <%= render "messages/message", message: in_progress, chat: @chat %>
          <% else %>
            <%# Still in the retrieval phases (no assistant bubble yet): the standalone
                animation receives phase updates and broadcast_created removes it.
                Its root carries id="thinking_animation" (see messages/_thinking). %>
            <%= render "messages/thinking" %>
          <% end %>
        <% end %>
      <% end %>
      <%= turbo_stream_from @chat, :messages %>
      <%= turbo_stream_from @chat, :token_totals %>
    </div>
  </section>
  <section class="w-full max-w-4xl mx-auto">
    <div class="mx-auto pointer-events-auto rounded-2xl bg-white dark:bg-neutral-800 shadow-xl ring-1 ring-neutral-200 dark:ring-neutral-700 p-4">
      <%= render partial: "messages/form", locals: { chat: @chat } %>
    </div>
  </section>

  <%# MCP Selector Modal %>
  <%= render "chats/mcp_selector", chat: @chat %>
</div>
