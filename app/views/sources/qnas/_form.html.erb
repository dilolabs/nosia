<%= form_with(model: [:sources, qna]) do |form| %>
  <div class="n-form-field">
    <%= form.label :question, "Question", class: "n-label" %>
    <%= form.text_field :question, class: "n-field" %>
  </div>

  <div class="n-form-field">
    <%= form.label :answer, "Answer", class: "n-label" %>
    <%# attachments: "false" hides both toolbar upload buttons (image + file)
        and disables uploads -- source editors are text-only. %>
    <%= form.lexxy_rich_text_area :answer,
          value: Commonmarker.to_html(qna.answer.to_s.encode("UTF-8")),
          class: "n-textarea",
          attachments: "false" %>
  </div>

  <div class="n-form-field">
    <%= form.label :account_id, "Account", class: "n-label" %>
    <%= form.collection_select :account_id,
                           Current.user.accounts,
                           :id,
                           :name,
                           { prompt: true, selected: Current.account, required: true },
                           { class: "n-select" } %>
  </div>

  <div class="n-form-actions">
    <%= form.submit "Save", class: "n-btn-primary" %>
  </div>
<% end %>
