<div class="n-title-container md:flex md:justify-between md:items-center">
  <h2 class="n-main-title">Edit Q&A #<%= @qna.id %></h2>
  <%= link_to sources_qna_path(@qna), class: "n-btn-secondary" do %>
    <%= inline_svg "svg/return-up-back.svg", title:"Retour", alt:"Retour", class: "mx-auto w-6 h-6" %>
    <span class="sr-only">Retour</span>
  <% end %>
</div>
<div class="n-form-container">
  <%= render "form", qna: @qna %>
</div>
