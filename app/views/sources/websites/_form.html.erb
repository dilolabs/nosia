<%= form_with(model: [:sources, website]) do |form| %>
  <div class="n-form-field">
    <%= form.label :url, "URL", class: "n-label" %>
    <%= form.url_field :url, class: "n-field" %>
  </div>

  <div class="n-form-field">
    <%= form.label :data, "Data", class: "n-label" %>
    <%# website.to_html renders the body only (page_body strips the crawl's
        --- frontmatter --- block). Saving the edited body therefore writes
        body-only markdown back to data, dropping the frontmatter. That's
        intended: nothing reads the frontmatter (Website#title comes from the
        H1, to_html strips it), and a re-crawl regenerates it. %>
    <%= form.lexxy_rich_text_area :data,
          value: website.to_html,
          class: "n-textarea",
          permitted_attachment_types: "" %>
  </div>

  <div class="n-form-field">
    <%= form.label :account_id, "Account", class: "n-label" %>
    <%= form.collection_select :account_id,
                           Current.user.accounts,
                           :id,
                           :name,
                           { prompt: true, selected: Current.account, required: true },
                           { class: "n-select" } %>
  </div>

  <div class="n-form-actions">
    <%= form.submit "Save", class: "n-btn-primary" %>
  </div>
<% end %>
