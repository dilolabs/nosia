<div class="n-title-container flex justify-between items-center">
  <h2 class="n-main-title"><%= @agent_skill.name %></h2>
  <div class="flex items-center gap-2">
    <%= link_to "Edit", edit_agent_skill_path(@agent_skill), class: "n-btn-primary" %>
    <%= link_to "Back", agent_skills_path, class: "n-btn" %>
  </div>
</div>

<div class="my-4 max-w-4xl space-y-4">
  <div class="n-card n-main-border">
    <div class="m-6 space-y-4">
      <div class="flex flex-wrap items-center gap-2">
        <span class="n-tag <%= @agent_skill.enabled? ? "n-tag-ready" : "n-tag-disconnected" %>">
          <%= @agent_skill.enabled? ? "Enabled" : "Disabled" %>
        </span>
        <span class="n-tag n-tag-disconnected"><%= @agent_skill.execution_mode.humanize %></span>
        <span class="n-tag n-tag-disconnected"><%= @agent_skill.trigger_mode.humanize %></span>
        <% if @agent_skill.requires_rag_context %>
          <span class="n-tag n-tag-connecting">Requires RAG context</span>
        <% end %>
      </div>

      <div>
        <p class="n-label font-medium">Description</p>
        <div class="text-sm text-neutral-700 dark:text-neutral-300">
          <%= simple_format(@agent_skill.description) %>
        </div>
      </div>

      <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
        <div>
          <dt class="text-neutral-500 dark:text-neutral-400">Execution mode</dt>
          <dd class="font-medium"><%= @agent_skill.execution_mode.humanize %></dd>
        </div>
        <div>
          <dt class="text-neutral-500 dark:text-neutral-400">Trigger mode</dt>
          <dd class="font-medium"><%= @agent_skill.trigger_mode.humanize %></dd>
        </div>
        <div>
          <dt class="text-neutral-500 dark:text-neutral-400">RAG context</dt>
          <dd class="font-medium"><%= @agent_skill.requires_rag_context ? "Yes" : "No" %></dd>
        </div>
        <div>
          <dt class="text-neutral-500 dark:text-neutral-400">Priority</dt>
          <dd class="font-medium"><%= @agent_skill.priority %></dd>
        </div>
      </dl>
    </div>
  </div>

  <div class="n-card n-main-border">
    <div class="m-6 space-y-3">
      <h3 class="font-semibold">SKILL.md content</h3>
      <pre class="bg-neutral-100 dark:bg-neutral-900 text-neutral-800 dark:text-neutral-200 p-4 rounded-lg overflow-x-auto text-sm font-mono whitespace-pre-wrap"><%= @agent_skill.skill_content_text %></pre>
    </div>
  </div>
</div>
