<%# The user message and thinking animation are delivered via the
    [chat, "messages"] broadcast (Message#broadcast_created), so every tab open
    on this chat — including this one — receives them exactly once. Here we only
    reset the composer (rendered busy from the generating flag). %>
<%= turbo_stream.replace "#{dom_id(@chat)}_message_form" do %>
  <%= render "form", chat: @chat %>
<% end %>
