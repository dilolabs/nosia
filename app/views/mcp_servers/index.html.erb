<% content_for :navbar do %>
  <li class="flex items-center">
    <%= link_to "Settings", settings_path, class:"n-ariane n-main-focus" %>
  </li>
  <li class="flex gap-1 items-center">
    <%= inline_svg_tag "svg/chevron-right.svg", class: "shrink-0 h-5 w-5" %>
    <%= link_to "MCP servers", mcp_servers_path, class:"n-ariane n-main-focus" %>
  </li>
<% end %>

<div class="n-title-container md:flex md:justify-between md:items-center">
  <h2 class="n-main-title">MCP Servers</h2>
  <div class="flex items-center gap-2">
    <%= link_to mcp_catalog_index_path, class: "n-btn border n-main-border n-main-hover n-main-focus inline-flex items-center gap-2" do %>
      <%= inline_svg_tag "svg/folders.svg", title: "Catalog", alt: "Folders", class: "w-5 h-5" %>
      <span>Catalog</span>
    <% end %>
    <%= link_to new_mcp_server_path, class: "n-btn-primary inline-flex items-center gap-2" do %>
      <%= inline_svg_tag "svg/plus.svg", title: "Add server", alt: "Plus", class: "w-5 h-5" %>
      <span>Add server</span>
    <% end %>
  </div>
</div>

<%= form_with url: mcp_servers_path, method: :get, class: "mb-4 flex flex-wrap items-center gap-2" do |f| %>
  <%= f.select :status,
    options_for_select([
      ["All statuses", ""],
      ["Ready", "ready"],
      ["Disconnected", "disconnected"],
      ["Error", "error"],
      ["Disabled", "disabled"]
    ], params[:status]),
    {},
    class: "n-select w-auto" %>

  <%= f.select :transport_type,
    options_for_select([
      ["All types", ""],
      ["Streamable HTTP", "streamable"],
      ["SSE", "sse"],
      ["STDIO", "stdio"]
    ], params[:transport_type]),
    {},
    class: "n-select w-auto" %>

  <%= f.submit "Filter", class: "n-btn-primary" %>
  <%= link_to "Reset", mcp_servers_path, class: "n-btn border n-main-border n-main-hover-tertiary n-main-focus-tertiary content-center" %>
<% end %>

<% if @mcp_servers.any? %>
  <ul class="n-cards-grid !list-none">
    <% @mcp_servers.each do |server| %>
      <%= render "mcp_server", server: server %>
    <% end %>
  </ul>
<% else %>
  <div class="n-card n-main-border my-4 lg:col-span-2">
    <div class="m-6 flex flex-col items-center text-center gap-3 py-8">
      <%= inline_svg_tag "svg/window.svg", title: "MCP servers", alt: "Window", class: "w-12 h-12 text-neutral-400" %>
      <p class="n-card-title text-wrap">No MCP servers found</p>
      <p class="n-card-subtitle text-wrap">Connect a Model Context Protocol server or activate one from the catalog.</p>
      <div class="flex items-center gap-2 mt-2">
        <%= link_to "Browse catalog", mcp_catalog_index_path, class: "n-btn border n-main-border n-main-hover n-main-focus" %>
        <%= link_to "Add server", new_mcp_server_path, class: "n-btn-primary" %>
      </div>
    </div>
  </div>
<% end %>
